# ============================================================
# secrets.py — HMAC 서명 비밀키 (GitHub 비공개)
#
# [설정 방법]
# 1. 이 파일을 secrets.py 로 복사
#      cp secrets.py.example secrets.py
# 2. 아래 값을 강력한 랜덤 문자열로 변경
#      - WiFi 비밀번호와 다른 값 사용
#      - SignedOTA/secrets.h 의 hmac_secret 과 반드시 동일해야 함
#
# [주의]
# - secrets.py 는 .gitignore 에 포함되어 GitHub 에 올라가지 않음
# - 이 파일(secrets.py.example)만 GitHub 에 올라감
# ============================================================

HMAC_SECRET = "CHANGE_THIS_TO_YOUR_SECRET"
